<h3>Version Availability Analysis</h3>
<p>This analyzer checks if extensions are available in TYPO3 Extension Repository (TER), Packagist, and VCS repositories for the target TYPO3 version.</p>

{% set enabled_sources = configuration.analysis.analyzers.version_availability.sources ?? ['ter', 'packagist', 'vcs'] %}

<table>
    <thead>
    <tr>
        <th></th>
        <th>Extension</th>
        <th>Current Version</th>
        {% if 'ter' in enabled_sources %}<th>TER</th>{% endif %}
        {% if 'packagist' in enabled_sources %}
            <th>Packagist</th>
            <th>Compatible</th>
            <th>Latest</th>
            <th></th>
        {% endif %}
        {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}<th>VCS</th>{% endif %}
        <th>Risk Level</th>
        {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}<th>Latest Version</th>{% endif %}
    </tr>
    </thead>
    <tbody>
    {% for data in extension_data %}
        <tr>
            <td>
                {% if data.version_analysis and data.version_analysis.distribution_type == 'path' %}
                    <span title="Local extension">🏠</span>
                {% elseif data.version_analysis and data.version_analysis.distribution_type is null %}
                    <span title="From Source">⛲️</span>
                {% endif %}
            </td>
            <td><strong><a href="extensions/{{ data.extension.key }}.html#version-availability-analysis" style="color: #ff8700; text-decoration: none;">{{ data.extension.key }}</a></strong></td>
            <td>{{ data.extension.version ? data.extension.version.toString() : 'N/A' }}</td>
            {% if data.version_analysis %}
                {% if 'ter' in enabled_sources %}
                    <td>
                        {% if data.version_analysis.skipped %}
                            <span class="status-unknown" title="{{ data.version_analysis.skip_reason }}">✖️</span>
                        {% else %}
                            <span class="{{ data.version_analysis.ter_available ? 'status-available' : 'status-unavailable' }}">{{ data.version_analysis.ter_available ? '✅' : '❌' }}</span>
                        {% endif %}
                    </td>
                {% endif %}
                {% if 'packagist' in enabled_sources %}
                    <td class="bd-orange-100">
                        {% if data.version_analysis.skipped %}
                            <span class="status-unknown" title="{{ data.version_analysis.skip_reason }}">✖️</span>
                        {% else %}
                            <span class="{{ data.version_analysis.packagist_available ? 'status-available' : 'status-unavailable' }}">{{ data.version_analysis.packagist_available ? '✅' : '❌' }}</span>
                        {% endif %}
                    </td>
                    <td class="bd-orange-100">
                        {% if data.version_analysis.skipped or not data.version_analysis.packagist_available %}
                             N/A
                        {% else %}
                             <span class="{{ data.version_analysis.packagist_latest_compatible ? 'status-available' : 'status-unavailable' }}">{{ data.version_analysis.packagist_latest_compatible ? '✅' : '❌' }}</span>
                        {% endif %}
                    </td>
                    <td class="bd-orange-100">
                        {% if data.version_analysis.packagist_latest_version and data.extension.composerName %}
                            <a href="https://packagist.org/packages/{{ data.extension.composerName }}" target="_blank" style="text-decoration: underline; color: #000;">{{ data.version_analysis.packagist_latest_version }}</a>
                        {% else %}
                            {{ data.version_analysis.packagist_latest_version ?: '' }}
                        {% endif %}
                    </td>
                    <td class="bd-orange-100">
                        {% if data.version_analysis.has_newer_packagist_version %}
                            <span title="Update available">🆙</span>
                        {% endif %}
                    </td>
                {% endif %}
                {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}
                    <td>
                        {% if data.version_analysis.skipped %}
                            <span class="status-unknown" title="{{ data.version_analysis.skip_reason }}">✖️</span>
                        {% elseif data.version_analysis.vcs_available is same as(true) %}
                            <span class="status-available">✅</span>
                        {% elseif data.version_analysis.vcs_available is same as(false) %}
                            <span class="status-unavailable">❌</span>
                        {% else %}
                            <span class="status-unknown" title="VCS resolution failed or not attempted">❓</span>
                        {% endif %}
                    </td>
                {% endif %}
                <td><span class="badge badge-{{ data.version_analysis.risk_level }}">{{ data.version_analysis.risk_level|upper }}</span></td>
                {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}
                    <td>{{ data.version_analysis.vcs_latest_version ?: 'N/A' }}</td>
                {% endif %}
            {% else %}
                {% if 'ter' in enabled_sources %}<td><span class="status-unknown">❓</span></td>{% endif %}
                {% if 'packagist' in enabled_sources %}<td><span class="status-unknown">❓</span></td><td>N/A</td><td>N/A</td><td></td>{% endif %}
                {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}<td><span class="status-unknown">❓</span></td>{% endif %}
                <td><span class="badge badge-unknown">UNKNOWN</span></td>
                {% if 'github' in enabled_sources or 'vcs' in enabled_sources %}<td>N/A</td>{% endif %}
            {% endif %}
        </tr>
    {% endfor %}
    </tbody>
</table>
