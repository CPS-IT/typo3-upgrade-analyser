<div class="section" id="version-availability-analysis">
    <h2>Version Availability Analysis</h2>

    {% set enabled_sources = configuration.analysis.analyzers.version_availability.sources ?? ['ter', 'packagist', 'git'] %}

    {% if extension_data.version_analysis %}
        {% set version_analysis = extension_data.version_analysis %}

        <h3>Availability Status</h3>
        {% if version_analysis.skipped %}
            <div class="status-grid">
                <div class="status-card">
                    <div class="status-icon unknown">✖️</div>
                    <strong>Analysis Skipped</strong><br>
                    <small>{{ version_analysis.skip_reason }}</small>
                </div>
            </div>
        {% else %}
            <div class="status-grid">
                <div class="status-card">
                    <div class="status-icon">
                        {{ version_analysis.distribution_type == 'path' ? '🏠' : (version_analysis.distribution_type is null ? '⛲️' : '📦') }}
                    </div>
                    <strong>Distribution</strong><br>
                    <small>{{ version_analysis.distribution_type == 'path' ? 'Local Path' : (version_analysis.distribution_type is null ? 'Source' : version_analysis.distribution_type|capitalize) }}</small>
                </div>
                <div class="status-card">
                    <div class="status-icon">{{ version_analysis.is_direct ? '🔗' : '↳' }}</div>
                    <strong>Dependency type</strong><br>
                    <small>{{ version_analysis.is_direct ? 'Direct' : 'Transitive' }}</small>
                </div>
                {% if 'ter' in enabled_sources %}
                    <div class="status-card">
                        <div class="status-icon {{ version_analysis.ter_available ? 'available' : 'unavailable' }}">
                            {{ version_analysis.ter_available ? '✅' : '❌' }}
                        </div>
                        <strong>TER</strong><br>
                        <small>TYPO3 Extension Repository</small>
                    </div>
                {% endif %}
                {% if 'packagist' in enabled_sources %}
                    <div class="status-card">
                        <div class="status-icon {{ version_analysis.packagist_available ? 'available' : 'unavailable' }}">
                            {{ version_analysis.packagist_available ? '✅' : '❌' }}
                        </div>
                        <strong>Packagist</strong><br>
                        <small>Composer Repository</small>
                    </div>
                {% endif %}
                {% if 'git' in enabled_sources or 'vcs' in enabled_sources %}
                    <div class="status-card">
                        {% if version_analysis.vcs_available == 'available' %}
                            <div class="status-icon available">✅</div>
                        {% elseif version_analysis.vcs_available == 'unavailable' %}
                            <div class="status-icon unavailable">❌</div>
                        {% else %}
                            <div class="status-icon unknown">❓</div>
                        {% endif %}
                        <strong>Git Repository</strong><br>
                        <small>{{ version_analysis.vcs_available == 'unknown' ? 'Resolution failed' : 'Source Code' }}</small>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {% if 'packagist' in enabled_sources and version_analysis.packagist_latest_version %}
            <h3>Package Information</h3>
            <div class="info-card">
                <p><strong>Latest Version:</strong> {% if extension_data.extension.composerName %}<a href="https://packagist.org/packages/{{ extension_data.extension.composerName }}" target="_blank">{{ version_analysis.packagist_latest_version }}</a>{% else %}{{ version_analysis.packagist_latest_version }}{% endif %}</p>
                <p><strong>Compatible with Target:</strong> <span class="{{ version_analysis.packagist_latest_compatible ? 'status-available' : 'status-unavailable' }}">{{ version_analysis.packagist_latest_compatible ? '✅ Yes' : '❌ No' }}</span></p>
            </div>
        {% endif %}

        {% if ('git' in enabled_sources or 'vcs' in enabled_sources) and (version_analysis.vcs_source_url or version_analysis.vcs_latest_version) %}
            <h3>Git Repository Information</h3>
            <div class="info-card">
                {% if version_analysis.vcs_source_url %}
                    <p><strong>Repository URL:</strong>
                        {% if version_analysis.vcs_source_url starts with 'http' %}
                            <a href="{{ version_analysis.vcs_source_url }}" target="_blank">{{ version_analysis.vcs_source_url }}</a>
                        {% else %}
                            <code>{{ version_analysis.vcs_source_url }}</code>
                        {% endif %}
                    </p>
                {% endif %}
                {% if version_analysis.vcs_latest_version %}
                    <p><strong>Latest Compatible Version:</strong> {{ version_analysis.vcs_latest_version }}</p>
                {% endif %}
            </div>
        {% endif %}

        <h3>Risk Analysis</h3>
        <p><strong>Risk Score:</strong> {{ "%.1f"|format(version_analysis.risk_score) }}/10.0</p>
        <p><strong>Risk Level:</strong> <span class="risk-indicator risk-{{ version_analysis.risk_level }}">{{ version_analysis.risk_level|upper }}</span></p>

        {% if version_analysis.recommendations %}
            <div class="recommendations">
                <h3>Recommendations</h3>
                <ul>
                {% for recommendation in version_analysis.recommendations %}
                    <li>{{ recommendation }}</li>
                {% endfor %}
                </ul>
            </div>
        {% endif %}
    {% else %}
        <div class="error-card">
            <h3>❌ Analysis Not Available</h3>
            <p>Version availability analysis was not performed for this extension. This may occur when:</p>
            <ul>
                <li>The analysis was not enabled</li>
                <li>There was an error fetching the available versions</li>
            </ul>
        </div>
    {% endif %}
</div>
