<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TYPO3 Upgrade Analysis Report</title>
    {% include 'html/partials/shared/styles.html.twig' %}
</head>
<body>
<div class="container">
    <div class="header">
        <h1>TYPO3 Upgrade Analysis Report</h1>
        <p>Generated: {{ generated_at.format('Y-m-d H:i:s T') }}</p>
    </div>

    <div class="content">
        {% include 'html/partials/main-report/installation-overview.html.twig' %}

        {% include 'html/partials/main-report/risk-distribution.html.twig' %}

        {% include 'html/partials/main-report/discovery-results.html.twig' %}

        <div class="section">
            <h2>Analyzer Results</h2>

            {% for analyzer in active_analyzers %}
                {% include analyzer.templates.html %}
            {% endfor %}
        </div>

        {% include 'html/partials/main-report/extension-links.html.twig' %}

        {% include 'html/partials/main-report/recommendations.html.twig' %}

        <div class="footer">
            <p>Report generated by TYPO3 Upgrade Analyzer</p>
        </div>
    </div>
</div>
</body>
</html>
