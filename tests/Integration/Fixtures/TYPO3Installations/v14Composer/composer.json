{
    "name": "myvendor/v14-composer-project",
    "description": "TYPO3 v14 Composer installation fixture",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.3",
        "typo3/cms-backend": "^14.0",
        "typo3/cms-core": "^14.0",
        "typo3/cms-extbase": "^14.0",
        "typo3/cms-frontend": "^14.0",
        "georgringer/news": "^12.0",
        "example/powermail": "^11.0"
    },
    "config": {
        "vendor-dir": "vendor",
        "bin-dir": "bin",
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    },
    "extra": {
        "typo3/cms": {
            "web-dir": "public"
        }
    },
    "autoload": {
        "psr-4": {
            "Test\\TestInstallation\\": "src/"
        }
    }
}
