<h3>TYPO3 Rector Analysis</h3>
<p>This analyzer uses TYPO3 Rector to detect deprecated code patterns, breaking changes, and upgrade requirements.</p>

{% set extensions_with_findings = extension_data|filter(d => d.rector_analysis is not null and d.rector_analysis.total_findings > 0) %}
{% set extensions_passing = extension_data|filter(d => d.rector_analysis is not null and d.rector_analysis.total_findings == 0) %}

{% if extensions_passing|length > 0 %}
<p>{{ extensions_passing|length }} extension{{ extensions_passing|length > 1 ? 's' : '' }} analyzed with 0 findings.</p>
{% endif %}

{% if extensions_with_findings|length > 0 %}
<table>
    <thead>
        <tr>
            <th>Extension</th>
            <th>Affected Files</th>
            <th>Total Findings</th>
            <th>Breaking Changes</th>
            <th>Deprecations</th>
            <th>Upgrade Readiness</th>
            <th>Fix Time (hrs)</th>
        </tr>
    </thead>
    <tbody>
        {% for data in extension_data %}
            {% if data.rector_analysis and data.rector_analysis.total_findings > 0 %}
                <tr>
                    <td><strong><a href="extensions/{{ data.extension.key }}.html#typo3-rector-analysis" style="color: #ff8700; text-decoration: none;">{{ data.extension.key }}</a></strong></td>
                    <td>{{ data.rector_analysis.processed_files }}</td>
                    <td>{{ data.rector_analysis.total_findings }}</td>
                    <td>{{ data.rector_analysis.has_breaking_changes ? '⚠️ Yes' : '✅ No' }}</td>
                    <td>{{ data.rector_analysis.has_deprecations ? '📋 Yes' : '✅ No' }}</td>
                    <td>{{ "%.1f"|format(data.rector_analysis.upgrade_readiness_score) }}/10</td>
                    <td>{{ "%.1f"|format(data.rector_analysis.estimated_fix_time_hours) }}</td>
                </tr>
            {% endif %}
        {% endfor %}
    </tbody>
</table>
{% endif %}
